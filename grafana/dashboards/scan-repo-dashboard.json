{
  "uid": "scan-repo-overview",
  "title": "Repo Compliance Scan (Elasticsearch)",
  "tags": ["elasticsearch", "scan-repo", "compliance"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "description": "Reads the RAW nested scan-repo-nested index directly (no flatten ETL). Aggregation panels count array elements via value_count/terms on the object-flattened arrays; the two detail tables show one row per scan with findings as JSON array cells (Grafana can't explode arrays into rows).",
  "templating": {
    "list": [
      {
        "name": "project",
        "label": "Project",
        "type": "query",
        "datasource": { "type": "elasticsearch", "uid": "es-scan-repo" },
        "query": "{\"find\": \"terms\", \"field\": \"project\"}",
        "includeAll": true, "multi": true, "allValue": "*",
        "current": { "text": "All", "value": "$__all" }, "refresh": 2
      },
      {
        "name": "repo",
        "label": "Repo",
        "type": "query",
        "datasource": { "type": "elasticsearch", "uid": "es-scan-repo" },
        "query": "{\"find\": \"terms\", \"field\": \"repoName\"}",
        "includeAll": true, "multi": true, "allValue": "*",
        "current": { "text": "All", "value": "$__all" }, "refresh": 2
      },
      {
        "name": "branch",
        "label": "Branch",
        "type": "query",
        "datasource": { "type": "elasticsearch", "uid": "es-scan-repo" },
        "query": "{\"find\": \"terms\", \"field\": \"branch\"}",
        "includeAll": true, "multi": true, "allValue": "*",
        "current": { "text": "All", "value": "$__all" }, "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Total findings",
      "description": "All scan findings (compliant + non-compliant). value_count on both arrays, summed per time bucket then over the range.",
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 0 },
      "datasource": { "type": "elasticsearch", "uid": "es-scan-repo" },
      "targets": [ { "refId": "A", "datasource": { "type": "elasticsearch", "uid": "es-scan-repo" },
        "query": "project:($project) AND repoName:($repo) AND branch:($branch)",
        "metrics": [
          { "id": "1", "type": "value_count", "field": "non_compliant.Reason", "hide": true },
          { "id": "3", "type": "value_count", "field": "compliant.Reason", "hide": true },
          { "id": "4", "type": "bucket_script",
            "pipelineVariables": [ { "name": "a", "pipelineAgg": "1" }, { "name": "b", "pipelineAgg": "3" } ],
            "settings": { "script": "params.a + params.b" } }
        ],
        "bucketAggs": [ { "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "auto", "min_doc_count": "0" } } ],
        "timeField": "@timestamp" } ],
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 2, "type": "stat", "title": "Non-compliant",
      "description": "Number of non-compliant findings (value_count of non_compliant array elements). Lower is better — red.",
      "gridPos": { "h": 4, "w": 5, "x": 5, "y": 0 },
      "datasource": { "type": "elasticsearch", "uid": "es-scan-repo" },
      "targets": [ { "refId": "A", "datasource": { "type": "elasticsearch", "uid": "es-scan-repo" },
        "query": "project:($project) AND repoName:($repo) AND branch:($branch)",
        "metrics": [ { "id": "1", "type": "value_count", "field": "non_compliant.Reason" } ],
        "bucketAggs": [ { "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "auto", "min_doc_count": "0" } } ],
        "timeField": "@timestamp" } ],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 3, "type": "stat", "title": "Compliant",
      "description": "Number of compliant findings (value_count of compliant array elements). Higher is better — green.",
      "gridPos": { "h": 4, "w": 5, "x": 10, "y": 0 },
      "datasource": { "type": "elasticsearch", "uid": "es-scan-repo" },
      "targets": [ { "refId": "A", "datasource": { "type": "elasticsearch", "uid": "es-scan-repo" },
        "query": "project:($project) AND repoName:($repo) AND branch:($branch)",
        "metrics": [ { "id": "1", "type": "value_count", "field": "compliant.Reason" } ],
        "bucketAggs": [ { "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "auto", "min_doc_count": "0" } } ],
        "timeField": "@timestamp" } ],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 4, "type": "piechart", "title": "Compliant vs Non-compliant",
      "description": "Share of compliant (green) vs non-compliant (red) findings. Two value_count series, one per array, reduced to totals.",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 0 },
      "datasource": { "type": "elasticsearch", "uid": "es-scan-repo" },
      "targets": [
        { "refId": "A", "alias": "non_compliant", "datasource": { "type": "elasticsearch", "uid": "es-scan-repo" },
          "query": "project:($project) AND repoName:($repo) AND branch:($branch)",
          "metrics": [ { "id": "1", "type": "value_count", "field": "non_compliant.Reason" } ],
          "bucketAggs": [ { "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "auto", "min_doc_count": "0" } } ],
          "timeField": "@timestamp" },
        { "refId": "B", "alias": "compliant", "datasource": { "type": "elasticsearch", "uid": "es-scan-repo" },
          "query": "project:($project) AND repoName:($repo) AND branch:($branch)",
          "metrics": [ { "id": "1", "type": "value_count", "field": "compliant.Reason" } ],
          "bucketAggs": [ { "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "auto", "min_doc_count": "0" } } ],
          "timeField": "@timestamp" }
      ],
      "transformations": [
        { "id": "reduce", "options": { "reducers": ["sum"], "includeTimeField": false, "mode": "seriesToRows" } }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [
        { "matcher": { "id": "byName", "options": "non_compliant" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
        { "matcher": { "id": "byName", "options": "compliant" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] }
      ] },
      "options": {
        "reduceOptions": { "values": true, "calcs": [] },
        "legend": { "displayMode": "list", "placement": "right", "values": ["value", "percent"] },
        "pieType": "pie"
      }
    },
    {
      "id": 5, "type": "barchart", "title": "Non-compliant by reason",
      "description": "Count of non-compliant findings grouped by reason (terms on non_compliant.Reason).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "elasticsearch", "uid": "es-scan-repo" },
      "targets": [ { "refId": "A", "datasource": { "type": "elasticsearch", "uid": "es-scan-repo" },
        "query": "project:($project) AND repoName:($repo) AND branch:($branch)",
        "metrics": [ { "id": "1", "type": "count" } ],
        "bucketAggs": [ { "id": "2", "type": "terms", "field": "non_compliant.Reason", "settings": { "size": "15", "order": "desc", "orderBy": "_count" } } ],
        "timeField": "@timestamp" } ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 80 } }, "overrides": [] },
      "options": { "orientation": "horizontal", "showValue": "auto" }
    },
    {
      "id": 6, "type": "barchart", "title": "Findings by repo — compliant vs non-compliant",
      "description": "One bar per repository. Green = compliant findings (value_count of compliant array), red = non-compliant, stacked. Two queries merged by repoName.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "elasticsearch", "uid": "es-scan-repo" },
      "targets": [
        { "refId": "A", "datasource": { "type": "elasticsearch", "uid": "es-scan-repo" },
          "query": "project:($project) AND repoName:($repo) AND branch:($branch)",
          "metrics": [
            { "id": "1", "type": "value_count", "field": "non_compliant.Reason" },
            { "id": "3", "type": "value_count", "field": "compliant.Reason" }
          ],
          "bucketAggs": [ { "id": "2", "type": "terms", "field": "repoName", "settings": { "size": "20", "order": "desc", "orderBy": "_count" } } ],
          "timeField": "@timestamp" }
      ],
      "transformations": [
        { "id": "organize", "options": {
          "excludeByName": {},
          "renameByName": {
            "value_count non_compliant.Reason": "non_compliant",
            "value_count compliant.Reason": "compliant"
          }
        } }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 85, "stacking": { "mode": "normal" }, "gradientMode": "none" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "non_compliant" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }, { "id": "displayName", "value": "Non-compliant" } ] },
          { "matcher": { "id": "byName", "options": "compliant" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }, { "id": "displayName", "value": "Compliant" } ] }
        ]
      },
      "options": { "orientation": "horizontal", "showValue": "always", "stacking": "normal", "xField": "repoName", "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 7, "type": "timeseries", "title": "Findings over time by severity",
      "description": "Non-compliant findings over time, grouped by severity (terms on non_compliant.severity). Note: a scan with two findings of the same severity is counted once per bucket, so this can undercount slightly vs the exact total.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "elasticsearch", "uid": "es-scan-repo" },
      "targets": [ { "refId": "A", "datasource": { "type": "elasticsearch", "uid": "es-scan-repo" },
        "query": "project:($project) AND repoName:($repo) AND branch:($branch)",
        "metrics": [ { "id": "1", "type": "count" } ],
        "bucketAggs": [
          { "id": "3", "type": "terms", "field": "non_compliant.severity", "settings": { "size": "5", "order": "desc", "orderBy": "_count" } },
          { "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "auto", "min_doc_count": "0" } }
        ],
        "timeField": "@timestamp" } ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 70, "stacking": { "mode": "normal" } } }, "overrides": [] }
    },
        {

          "id": 8,
          "type": "table",
          "title": "Non-compliant findings",
          "description": "One row per non-compliant finding, exploded from the nested scan documents via the Infinity datasource (JSONata). Elasticsearch keeps the raw nested arrays.",
          "gridPos": {
            "h": 10,
            "w": 24,
            "x": 0,
            "y": 20
          },
          "datasource": {
            "type": "yesoreyeram-infinity-datasource",
            "uid": "es-infinity"
          },
          "targets": [
            {
              "refId": "A",
              "datasource": {
                "type": "yesoreyeram-infinity-datasource",
                "uid": "es-infinity"
              },
              "type": "json",
              "parser": "backend",
              "source": "url",
              "format": "table",
              "url": "http://elasticsearch:9200/scan-repo-nested/_search",
              "url_options": {
                "method": "POST",
                "body_type": "raw",
                "body_content_type": "application/json",
                "data": "{\"size\":100,\"query\":{\"bool\":{\"filter\":[{\"query_string\":{\"query\":\"project:(${project:lucene}) AND repoName:(${repo:lucene}) AND branch:(${branch:lucene})\"}},{\"range\":{\"@timestamp\":{\"gte\":\"${__from:date:iso}\",\"lte\":\"${__to:date:iso}\"}}}]}}}"
              },
              "root_selector": "$count(hits.hits) > 0 ? hits.hits.($s:=_source; $s.non_compliant.{\"Time\":$s.`@timestamp`,\"severity\":severity,\"repoName\":$s.repoName,\"branch\":$s.branch,\"project\":$s.project,\"Endpoint\":Endpoint,\"FileName\":FileName,\"Line\":Line,\"Reason\":Reason,\"Suggestion\":Suggestion}) : []",
              "columns": [
                {
                  "selector": "Time",
                  "text": "Time",
                  "type": "timestamp",
                  "timestampformat": "2006-01-02T15:04:05Z"
                },
                {
                  "selector": "severity",
                  "text": "severity",
                  "type": "string"
                },
                {
                  "selector": "repoName",
                  "text": "repoName",
                  "type": "string"
                },
                {
                  "selector": "branch",
                  "text": "branch",
                  "type": "string"
                },
                {
                  "selector": "project",
                  "text": "project",
                  "type": "string"
                },
                {
                  "selector": "Endpoint",
                  "text": "Endpoint",
                  "type": "string"
                },
                {
                  "selector": "FileName",
                  "text": "FileName",
                  "type": "string"
                },
                {
                  "selector": "Line",
                  "text": "Line",
                  "type": "number"
                },
                {
                  "selector": "Reason",
                  "text": "Reason",
                  "type": "string"
                },
                {
                  "selector": "Suggestion",
                  "text": "Suggestion",
                  "type": "string"
                }
              ]
            }
          ],
          "transformations": [
            {
              "id": "organize",
              "options": {
                "excludeByName": {},
                "renameByName": {},
                "indexByName": {
                  "Time": 0,
                  "severity": 1,
                  "repoName": 2,
                  "branch": 3,
                  "project": 4,
                  "Endpoint": 5,
                  "FileName": 6,
                  "Line": 7,
                  "Reason": 8,
                  "Suggestion": 9
                }
              }
            }
          ],
          "fieldConfig": {
            "defaults": {
              "custom": {
                "filterable": true
              }
            },
            "overrides": []
          },
          "options": {
            "showHeader": true
          }
        },
        } }
      ],
      "fieldConfig": { "defaults": { "custom": { "filterable": true } }, "overrides": [] },
      "options": { "showHeader": true }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Compliant findings",
      "description": "One row per compliant finding, exploded from the nested scan documents via the Infinity datasource (JSONata). Elasticsearch keeps the raw nested arrays.",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 30
      },
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "es-infinity"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "yesoreyeram-infinity-datasource",
            "uid": "es-infinity"
          },
          "type": "json",
          "parser": "backend",
          "source": "url",
          "format": "table",
          "url": "http://elasticsearch:9200/scan-repo-nested/_search",
          "url_options": {
            "method": "POST",
            "body_type": "raw",
            "body_content_type": "application/json",
            "data": "{\"size\":100,\"query\":{\"bool\":{\"filter\":[{\"query_string\":{\"query\":\"project:(${project:lucene}) AND repoName:(${repo:lucene}) AND branch:(${branch:lucene})\"}},{\"range\":{\"@timestamp\":{\"gte\":\"${__from:date:iso}\",\"lte\":\"${__to:date:iso}\"}}}]}}}"
          },
          "root_selector": "$count(hits.hits) > 0 ? hits.hits.($s:=_source; $s.compliant.{\"Time\":$s.`@timestamp`,\"repoName\":$s.repoName,\"branch\":$s.branch,\"project\":$s.project,\"Endpoint\":Endpoint,\"FileName\":FileName,\"Line\":Line,\"Reason\":Reason,\"Suggestion\":Suggestion}) : []",
          "columns": [
            {
              "selector": "Time",
              "text": "Time",
              "type": "timestamp",
              "timestampformat": "2006-01-02T15:04:05Z"
            },
            {
              "selector": "repoName",
              "text": "repoName",
              "type": "string"
            },
            {
              "selector": "branch",
              "text": "branch",
              "type": "string"
            },
            {
              "selector": "project",
              "text": "project",
              "type": "string"
            },
            {
              "selector": "Endpoint",
              "text": "Endpoint",
              "type": "string"
            },
            {
              "selector": "FileName",
              "text": "FileName",
              "type": "string"
            },
            {
              "selector": "Line",
              "text": "Line",
              "type": "number"
            },
            {
              "selector": "Reason",
              "text": "Reason",
              "type": "string"
            },
            {
              "selector": "Suggestion",
              "text": "Suggestion",
              "type": "string"
            }
          ]
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "renameByName": {},
            "indexByName": {
              "Time": 0,
              "repoName": 1,
              "branch": 2,
              "project": 3,
              "Endpoint": 4,
              "FileName": 5,
              "Line": 6,
              "Reason": 7,
              "Suggestion": 8
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": true
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    }
        } }
      ],
      "fieldConfig": { "defaults": { "custom": { "filterable": true } }, "overrides": [] },
      "options": { "showHeader": true }
    }
  ]
}
