{
  "uid": "logs-overview",
  "title": "Logs Overview (Elasticsearch)",
  "tags": ["elasticsearch", "logs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "elasticsearch", "uid": "es-logs" },
        "query": "{\"find\": \"terms\", \"field\": \"service\"}",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total logs",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "elasticsearch", "uid": "es-logs" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "es-logs" },
          "query": "service:($service)",
          "metrics": [ { "id": "1", "type": "count" } ],
          "bucketAggs": [],
          "timeField": "@timestamp"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Avg response time (ms)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "elasticsearch", "uid": "es-logs" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "es-logs" },
          "query": "service:($service)",
          "metrics": [ { "id": "1", "type": "avg", "field": "response_time_ms" } ],
          "bucketAggs": [],
          "timeField": "@timestamp"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "decimals": 1 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 3,
      "type": "piechart",
      "title": "Logs by level",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "elasticsearch", "uid": "es-logs" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "es-logs" },
          "query": "service:($service)",
          "metrics": [ { "id": "1", "type": "count" } ],
          "bucketAggs": [ { "id": "2", "type": "terms", "field": "level", "settings": { "size": "10", "order": "desc", "orderBy": "_count" } } ],
          "timeField": "@timestamp"
        }
      ],
      "options": { "legend": { "displayMode": "list", "placement": "right", "values": ["value"] }, "pieType": "donut" }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Log volume over time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "elasticsearch", "uid": "es-logs" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "es-logs" },
          "query": "service:($service)",
          "metrics": [ { "id": "1", "type": "count" } ],
          "bucketAggs": [
            { "id": "3", "type": "terms", "field": "level", "settings": { "size": "5", "order": "desc", "orderBy": "_count" } },
            { "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "auto", "min_doc_count": "0" } }
          ],
          "timeField": "@timestamp"
        }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" }, "fillOpacity": 60 } }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Avg response time over time (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "elasticsearch", "uid": "es-logs" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "es-logs" },
          "query": "service:($service)",
          "metrics": [ { "id": "1", "type": "avg", "field": "response_time_ms" } ],
          "bucketAggs": [
            { "id": "3", "type": "terms", "field": "service", "settings": { "size": "10", "order": "desc", "orderBy": "_count" } },
            { "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "auto", "min_doc_count": "0" } }
          ],
          "timeField": "@timestamp"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 } }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Recent log messages",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "elasticsearch", "uid": "es-logs" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "es-logs" },
          "query": "service:($service)",
          "metrics": [ { "id": "1", "type": "logs" } ],
          "bucketAggs": [],
          "timeField": "@timestamp"
        }
      ],
      "options": { "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true, "enableLogDetails": true }
    }
  ]
}
